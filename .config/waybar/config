{
    "layer": "top",
    "position": "top",
    "height": 36,
    "margin-top": 12,
    "margin-left": 120,
    "margin-right": 120,
    "spacing": 0,
    "exclusive": true,

    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "mpris"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "battery",
        "clock",
        "tray"
    ],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "active-only": false,
        "all-outputs": false
    },

    "clock": {
        "format": "{:%a %d %b  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "on-click": "gsimplecal",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "today": "<u>{}</u>"
        }
    }
},
    "pulseaudio": {
        "format": "vol {volume}%",
        "format-muted": "muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ && wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2*100)}' > $XDG_RUNTIME_DIR/wob.sock",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2*100)}' > $XDG_RUNTIME_DIR/wob.sock",
        "scroll-step": 5,
        "tooltip-format": "{desc}"
    },

    "network": {
	"format-wifi": "{essid}",
        "format-ethernet": "eth",
        "format-disconnected": "offline",
        "tooltip-format": "{ipaddr}  {signalStrength}%",
        "max-length": 20
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {status}",
        "format-charging": "{capacity}% chg",
        "format-plugged": "{capacity}% ac",
        "format-full": "full",
        "tooltip-format": "{timeTo}"
    },

    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{status_icon} {title}",
        "player-icons": {
            "default": "▶",
            "spotify": "♫"
        },
        "status-icons": {
            "paused": "⏸"
        },
        "max-length": 30,
        "tooltip-format": "{title} — {artist}"
    },

    "tray": {
        "spacing": 10,
        "icon-size": 14
    }
}
